{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@screenshot/web", "dev"],
      "port": 5175,
      "autoPort": true
    },
    {
      "name": "web-preview",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@screenshot/web", "exec", "vite", "preview", "--port", "4173", "--strictPort"],
      "port": 4173
    }
  ]
}

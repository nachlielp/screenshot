{
    "name": "Screen Recorder",
    "description": "Capture your screen and share your ideas",
    "version": "1",
    "manifest_version": 3,
    "minimum_chrome_version": "116",
    "action": {
        "default_icon": {
            "16": "icons/not-recording.png",
            "32": "icons/not-recording.png"
        },
        "default_popup": "index.html"
    },
    "host_permissions": [
        "https://*/*",
        "http://*/*",
        "https://*.convex.cloud/*",
        "https://*.clerk.accounts.dev/*",
        "https://*.accounts.dev/*",
        "https://clerk.snap.nachli.com/*"
    ],
    "background": {
        "service_worker": "sw.js",
        "type": "module"
    },
    "permissions": [
        "tabCapture",
        "offscreen",
        "scripting",
        "storage",
        "desktopCapture",
        "tabs",
        "activeTab",
        "cookies"
    ],
    "content_scripts": [
        {
            "matches": ["https://*/*", "http://*/*"],
            "js": ["content.js"],
            "run_at": "document_start",
            "all_frames": false
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "page-interceptors.js",
                "video.html",
                "video.js",
                "editor.html",
                "editor.js",
                "slideshow-editor.html",
                "slideshow-editor.js",
                "import-image.html",
                "import-image.js",
                "library.html",
                "library.js",
                "snapshot-inspector.html",
                "snapshot-inspector.js",
                "auth-callback.html",
                "auth-callback.js",
                "clerk-sync.html",
                "auth-page.html",
                "auth-page.js"
            ],
            "matches": [
                "https://*/*",
                "http://*/*"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://*.convex.cloud https://*.clerk.accounts.dev https://clerk.clerk.accounts.dev https://*.clerk.com https://*.accounts.dev https://clerk.snap.nachli.com wss://*.convex.cloud"
    }
}

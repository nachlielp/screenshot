{
  "name": "screenshot",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @screenshot/web dev",
    "dev:convex": "npx convex dev",
    "dev": "concurrently \"pnpm dev:convex\" \"pnpm dev:web\"",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @screenshot/web build",
    "zip:ext": "pnpm --filter @screenshot/extension zip"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "convex": "^1.33.1"
  }
}
